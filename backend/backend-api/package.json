{
  "name": "brightworks-professional",
  "version": "3.3.0",
  "description": "Professional Cleaning Management System - Ultimate Edition with ISO/EPA Compliance",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "build:start": "npm run build:frontend && node server.js",
    "dev": "nodemon server.js",
    "dev:frontend": "vite",
    "build": "npm run build:frontend",
    "build:frontend": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port $PORT",
    "test": "echo \"No tests specified yet\" && exit 0",
    "lint": "eslint . --ext .js,.ts,.tsx --fix",
    "lint:frontend": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"**/*.{js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "clean": "rm -rf node_modules package-lock.json .next dist",
    "reinstall": "npm run clean && npm install",
    "setup-admin": "node createAdmin.js",
    "check-env": "node -e \"require('dotenv').config(); console.log('✅ Environment variables loaded successfully')\"",
    "production": "NODE_ENV=production node server.js",
    "postinstall": "echo \"✅ Dependencies installed successfully\"",
    "health": "curl -f http://localhost:10000/api/health || exit 1",
    "version-check": "node -v && npm -v",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cleaning",
    "management",
    "professional",
    "iso-compliance",
    "iso-9001",
    "iso-14001",
    "epa-certified",
    "task-management",
    "pwa",
    "progressive-web-app",
    "crm",
    "client-management",
    "budget-quotes",
    "time-tracking",
    "employee-management",
    "statistics",
    "analytics",
    "email-reports",
    "notes",
    "reminders"
  ],
  "author": {
    "name": "LELC Technology",
    "email": "info@lelc.tech",
    "url": "https://lelc.tech"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/brightworks-professional.git",
    "directory": "/"
  },
  "bugs": {
    "url": "https://github.com/yourusername/brightworks-professional/issues",
    "email": "support@brightworks.com"
  },
  "homepage": "https://brightworks-backend.onrender.com",
  "funding": {
    "type": "corporate",
    "url": "https://lelc.tech"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.2",
    "@sendgrid/mail": "^7.7.0",
    "@tanstack/react-query": "^5.8.4",
    "@tanstack/react-virtual": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "framer-motion": "^10.16.16",
    "helmet": "^7.1.0",
    "idb": "^8.0.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.294.0",
    "mongoose": "^8.0.3",
    "pdfkit": "^0.15.0",
    "morgan": "^1.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.0",
    "react-window": "^1.8.10",
    "recharts": "^2.10.3",
    "sharp": "^0.34.4",
    "tailwind-merge": "^2.1.0",
    "workbox-window": "^7.0.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "nodemon": "^3.0.2",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.5",
    "vite-plugin-pwa": "^0.17.4"
  },
  "bundledDependencies": [],
  "nodemonConfig": {
    "watch": [
      "server.js",
      "createAdmin.js",
      ".env",
      "routes/",
      "models/",
      "middleware/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "public/",
      "*.test.js",
      ".git/",
      "logs/",
      "*.log"
    ],
    "delay": "1000",
    "verbose": true,
    "env": {
      "NODE_ENV": "development"
    },
    "exec": "node"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "browser": false
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "no-process-exit": "off",
      "prefer-const": "warn",
      "no-var": "error",
      "eqeqeq": [
        "error",
        "always"
      ],
      "curly": [
        "error",
        "all"
      ],
      "indent": [
        "warn",
        2,
        {
          "SwitchCase": 1
        }
      ],
      "quotes": [
        "warn",
        "single",
        {
          "avoidEscape": true
        }
      ],
      "semi": [
        "error",
        "always"
      ]
    },
    "globals": {
      "__dirname": "readonly",
      "__filename": "readonly",
      "process": "readonly",
      "require": "readonly",
      "module": "readonly",
      "exports": "readonly",
      "Buffer": "readonly",
      "console": "readonly"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": false,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "always",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "bracketSameLine": false
  },
  "preferGlobal": false,
  "private": false,
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "bundleDependencies": []
}
